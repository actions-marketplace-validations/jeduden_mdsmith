          }
        },
        {
          "ruleId": "S004",
          "ruleIndex": 3,
          "level": "note",
          "message": {
            "text": "GOPATH fallback in resolveInstalledBinary can be steered by attacker-controlled environment"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "cmd/mdsmith/mergedriver.go"
                },
                "region": {
                  "startLine": 818,
                  "endLine": 821
                }
              }
            },
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "cmd/mdsmith/mergedriver.go"
                },
                "region": {
