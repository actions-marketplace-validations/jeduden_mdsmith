          }
        },
        {
          "ruleId": "S005",
          "ruleIndex": 4,
          "level": "note",
          "message": {
            "text": "Obsidian plugin configPath passed to vault adapter without path-traversal validation"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "editors/obsidian/src/main.ts"
                },
